{
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "6.5.0",
    "@mui/material": "6.5.0",
    "i18next": "26.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "17.0.1",
    "react-router-dom": "6.28.0"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "prettier": "3.8.1",
