    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/supertest": "^7",
    "eslint": "9.39.4",
    "eslint-plugin-oxlint": "1.58.0",
    "oxlint": "1.58.0",
    "prettier": "3.8.1",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.7.0",
