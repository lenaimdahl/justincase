    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "description": "The backend for JustInCase",
  "devDependencies": {
    "@ffflorian/eslint-config": "0.14.2",
    "@ffflorian/prettier-config": "0.6.7",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.17",
    "@types/bcrypt": "6.0.0",
    "@types/express": "5.0.6",
    "@types/node": "~24",
    "@types/passport": "1.0.17",
